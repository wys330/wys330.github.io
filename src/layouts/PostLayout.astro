---
import BaseLayout from './BaseLayout.astro';
import { formatDate, getReadingMinutes, type BlogPost } from '@/utils/posts';

type Props = {
  post: BlogPost;
};

const { post } = Astro.props;
const readingTime = getReadingMinutes(post.body ?? '');
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post-shell">
    <header class="post-hero">
      <a class="back-link" href="/blog/">← 返回文章列表</a>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="post-meta">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span>{readingTime}</span>
        {post.data.updatedDate && <span>更新于 {formatDate(post.data.updatedDate)}</span>}
      </div>
      <div class="tag-row" aria-label="文章标签">
        {post.data.tags.map((tag) => <a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
